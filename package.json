{
  "name": "pomodoro",
  "productName": "Pomodoro",
  "version": "1.0.0",
  "description": "A minimal pomodoro timer for macOS.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "env -u npm_config_user_agent electron-forge start",
    "package": "env -u npm_config_user_agent electron-forge package",
    "package:mac": "env -u npm_config_user_agent electron-forge package --platform=darwin --arch=arm64",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/plugin-fuses": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@electron/fuses": "1.8.0",
    "@tailwindcss/vite": "4.3.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "^43.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tailwindcss": "4.3.3",
    "typescript": "7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
